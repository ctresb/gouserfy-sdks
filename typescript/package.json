    "dev": "tsc --watch",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "typescript": "^5.3.0"
  },
  "keywords": [
    "gouserfy",
    "auth",
    "user-management",
    "sdk"
  ],
  "license": "MIT"
}

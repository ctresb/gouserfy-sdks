{
  "name": "@gouserfy/sdk",
  "version": "1.0.0",
  "description": "TypeScript SDK for Gouserfy user management",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
